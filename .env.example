# ==============================================================================
# Environment variables example for SmartRetailSystem
# Copy this file to '.env' in the root directory before running the system.
# ==============================================================================

# Database Configuration
# MongoDB connection URI (use your local or cloud MongoDB database URL)
# Inside Docker Compose, this is automatically configured to use the internal database container.
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/smartretaildb

# JWT Security Configurations
# Secret key used to sign and verify JWT tokens (must be at least 256-bits / 32 characters long)
APP_JWT_SECRET=YourSuperSecretKeyMustBeAtLeast32CharactersLongAndSecure!

# Token expiration duration in milliseconds (86400000 = 24 hours)
APP_JWT_EXPIRATION=86400000

# Custom Inventory Threshold
# Product stock level that triggers warnings (default: 10)
APP_INVENTORY_LOW_STOCK_THRESHOLD=10

# Server port configuration for local execution
SERVER_PORT=8080
