# ==============================================================================
# Root .gitignore for Smart Retail Operations and Inventory Management System
# ==============================================================================

# IDE & Editor files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# System Files
.DS_Store
Thumbs.db
ehthumbs.db

# Dependency directories (regenerated via package managers)
node_modules/
jspm_packages/
web_drivers/
backend/target/
frontend/dist/
frontend/node_modules/

# Local configuration files (contains credentials)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Packages / Archives
*.zip
*.tar.gz
*.rar
